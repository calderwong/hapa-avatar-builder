{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapa.local/schemas/hapa-card-envelope-v1.schema.json",
  "title": "Hapa Cross-App Card Envelope v1",
  "type": "object",
  "required": ["schemaVersion", "cardId", "source", "lineage", "truthStatus", "projection"],
  "properties": {
    "schemaVersion": {
      "const": "hapa.card-envelope.v1"
    },
    "cardId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": ["system", "store", "runIds"],
      "properties": {
        "system": { "type": "string", "minLength": 1 },
        "store": { "type": "string", "minLength": 1 },
        "path": { "type": ["string", "null"] },
        "runIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "required": ["sourceCardIds"],
      "properties": {
        "parentCardId": { "type": ["string", "null"] },
        "sourceCardIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "truthStatus": {
      "type": "string",
      "minLength": 1
    },
    "projection": {
      "type": "object",
      "required": ["consumer", "readOnly", "projectedAt"],
      "properties": {
        "consumer": { "type": "string", "minLength": 1 },
        "readOnly": { "const": true },
        "projectedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
